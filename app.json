{
  "expo": {
    "name": "My React Native App",
    "slug": "my-react-native-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.adam-amr.my-react-native-app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      }
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "cameraPermission": "CampusCare needs camera access so you can take a photo for a facility ticket.",
          "photosPermission": "CampusCare needs photo library access so you can attach an existing image to a facility ticket."
        }
      ],
      "expo-notifications"
    ],
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "eas": {
        "projectId": "f19bdbab-ea36-4c32-96a8-91ca5b34f5c6"
      }
    },
    "owner": "adam-amr"
  }
}
